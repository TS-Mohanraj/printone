 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Tax Invoice</title>\n\n<style>\n@page {\n    margin: 0;\n}\n\nbody {\n    margin: 0;\n    font-family: Arial, Helvetica, sans-serif;\n    background-color: #ffffff;\n}\n\n.invoice-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 0;\n    position: relative;\n}\n\n.left-section {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n}\n\n.logo {\n    width: 200px;\n    height: 120px;\n    object-fit: contain;\n}\n\n.center-title {\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 22px;\n    font-weight: 600;\n    color: #000;\n}\n\n.right-section {\n    text-align: right;\n    font-size: 14px;\n    line-height: 1.6;\n    color: #1e88c8;\n    font-weight: 600;\n}\n\n.divider {\n    height: 6px;\n    background-color: #000;\n    width: 100%;\n}\n\n/* \u2705 T/* TABLE */\n.table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 13px;\n}\n\n/* ALL CELLS */\n.table th, \n.table td {\n    padding: 8px;\n    border-right: 1px solid #ccc;   /* \u2705 vertical lines */\n}\n\n/* REMOVE LAST COLUMN RIGHT BORDER */\n.table th:last-child,\n.table td:last-child {\n    border-right: none;\n}\n\n/* HEADER STYLE */\n.table th {\n    background-color: #2c8fb8;  /* \u2705 blue background */\n    color: #ffffff;             /* \u2705 white text */\n    border-bottom: 1px solid #ccc;\n    text-align: center;\n}\n\n/* ROW DIVIDER */\n.row-line {\n    border-bottom: 1px solid #ddd;\n}\n\n/* RIGHT ALIGN */\n.right {\n    text-align: right;\n}\n\n/* TOTAL ROW */\n.total-row td {\n    border-right: none !important; \n    border-top: 1px solid #ccc;\n    font-weight: bold;\n}\n\n/* TOTALS TABLE */\n.totals-table {\n    width: 100%;\n    margin-top: 10px;\n    border-collapse: collapse;\n}\n\n.totals-table td {\n    padding: 10px 10px;\n}\n\n/* LEFT SIDE (labels) */\n.label {\n    text-align: right;\n    width: 85%;\n}\n\n/* RIGHT SIDE (values) */\n.value {\n    text-align: right;\n    width: 15%;\n}\n\n.amount-words {\n    margin-top: 10px;\n}\n</style>\n</head>\n\n<body>\n\n<div class=\"invoice-header\">\n\n    <div class=\"left-section\">\n        <img src=\"https://printone.ae/wp-content/uploads/2025/07/prinone-it-equipment-solutions-printer-rental-logo-1.png\" class=\"logo\">\n    </div>\n\n    <div class=\"center-title\">Tax Invoice</div>\n\n    <div class=\"right-section\">\n        PRINTONE TRADING LLC<br>\n        TRN: 100269896500003<br>\n        P.O. BOX: 35504<br>\n        Dubai, United Arab Emirates\n    </div>\n\n</div>\n\n<div class=\"divider\"></div>\n\n<div class=\"invoice-details\">\n\n    <div class=\"top-section\">\n        <div class=\"left-info\">\n            <p><strong>Invoice No</strong> : {{ doc.name }}</p>\n            <p><strong>Invoice Date</strong> : {{ frappe.utils.formatdate(doc.posting_date, \"dd-mm-yyyy\") }}</p>\n        </div>\n\n        <div class=\"right-info\">\n            <p><strong>Payment Due Date</strong> : {{ frappe.utils.formatdate(doc.due_date, \"dd-mm-yyyy\") }}</p>\n            <p><strong>Amount Due</strong> : {{ doc.base_total }}</p>\n        </div>\n    </div>\n<!-- ADDRESS TABLE -->\n{% set bill_addr = frappe.get_doc(\"Address\", doc.address) %}\n\n<table class=\"address-table\">\n\n    <!-- HEADER -->\n    <tr>\n        <th style=\"width:50%\">Bill To:</th>\n        <th style=\"width:50%\">Ship To:</th>\n    </tr>\n\n    <!-- CONTENT -->\n    <tr>\n        <!-- BILL TO -->\n        <td>\n            <strong>{{ doc.customer }}</strong><br>\n                {{ bill_addr.address_line1}}<br>\n                {{ bill_addr.city or \"\" }}, {{ bill_addr.pincode or \"\" }}<br>\n                {{ bill_addr.country or \"\" }}<br>\n                PO Box: {{ bill_addr.pincode or \"\" }}<br>\n                Phone: {{ bill_addr.phone or \"\" }}<br>\n                Email: {{ bill_addr.email_id or \"\" }}<br>\n\n            TRN : {{ doc.tax_id or \"104380737700003\" }}\n        </td>\n\n        <!-- SHIP TO -->\n        <td>\n                <strong>{{\" \"}}</strong><br>\n                {{ \" \" }}<br>\n                {{ \" \" }}<br>\n                {{ \" \" }}, {{ \" \" }}<br>\n                {{ \" \" }}\n        </td>\n    </tr>\n\n</table>\n\n<!-- TABLE -->\n<table class=\"table\">\n    <thead>\n        <tr>\n            <th style=\"width:5%\">SL</th>\n            <th style=\"width:40%\">Description</th>\n            <th>From Date</th>\n            <th>To Date</th>\n            <th class=\"right\">Qty</th>\n            <th>UOM</th>\n            <th class=\"right\">Rate</th>\n            <th class=\"right\">Amount</th>\n        </tr>\n    </thead>\n\n    <tbody>\n        {% for item in doc.items %}\n        <tr class=\"row-line\">\n            <td>{{ loop.index }}</td>\n\n            <td>\n                {{ item.item_name or \"\" }}\n                {% if item.description %}\n                <div>{{ item.description }}</div>\n                {% endif %}\n            </td>\n            <td>{{ frappe.utils.formatdate(doc.posting_date, \"dd-mm-yyyy\") }}</td>\n            <td>{{ frappe.utils.formatdate(doc.due_date, \"dd-mm-yyyy\") }}</td>\n\n            <td class=\"right\">{{ item.qty }}</td>\n            <td>{{ item.uom }}</td>\n            <td class=\"right\">{{ item.rate }}</td>\n            <td class=\"right\">{{ item.amount }}</td>\n        {% endfor %}\n\n        <tr class=\"total-row\">\n            <td></td> <!-- SL -->\n            <td class=\"right\"><strong>Total</strong></td> <!-- Description -->\n            <td></td>\n            <td></td>\n            <td class=\"right\"><strong>{{ doc.items | sum(attribute='qty') }}</strong></td> <!-- Qty -->\n            <td></td> <!-- UOM -->\n            <td></td> <!-- Rate -->\n            <td class=\"right\"><strong>{{ doc.net_total }}</strong></td> <!-- Amount -->\n        </tr>\n       </tr>\n    </tbody>\n</table>\n\n<!-- SUMMARY -->\n<table style=\"width:100%; border-collapse:collapse; margin-top:10px;\">\n    <tr>\n        <td style=\"width:80%; text-align:right; padding:6px 10px; border-top: 3px solid #e0e0e0;\">\n            <strong>Net Total</strong>\n        </td>\n        <td style=\"width:20%; text-align:right; padding:6px 10px; border-top: 3px solid #e0e0e0;\">\n            {{ doc.net_total }}\n        </td>\n    </tr>\n\n    <tr style=\"border-bottom: 1px solid #e0e0e0;\">\n        <td style=\"width:50%; text-align:right; padding:6px 10px; border-top: 3px solid #e0e0e0;\">\n            <strong>Grand Total</strong>\n        </td>\n        <td style=\"width:50%; text-align:right; padding:6px 6px; border-top: 3px solid #e0e0e0;\">\n            {{ doc.grand_total }}\n        </td>\n    </tr>\n</table>\n\n<div class=\"amount-words\">\n    Amount In Words: {{ doc.in_words }}\n</div>\n\n<div style=\"width: 100%; margin-top: 10px; font-size: 11px; font-family: Arial, sans-serif;\">\n    <div style=\"background-color: white; padding: 10px; border: 1px solid #999;\">\n        <strong>Terms And Conditions</strong>\n        <div style=\"margin-top: 5px;\">\n            <p style=\"margin: 2px 0;\">Bank Name : RAK Bank</p>\n            <p style=\"margin: 2px 0;\">IBAN No : AE280400000352597179001</p>\n            <p style=\"margin: 2px 0;\">SWIFT Code : NRAKAEAK</p>\n            <p style=\"margin: 2px 0;\">A/C No : 0352597179001</p>\n            <p style=\"margin: 2px 0;\">Routing Code : 804020101</p>\n        </div>\n    </div>\n</div>\n\n</body>\n</html>",
