 "css": ".top-section {\n    display: flex;\n    justify-content: space-between;\n    gap: 120px; \n    padding: 20px 20px;\n    font-size:15px;\n}\n\n.left-info {\n    width: 50%;\n}\n\n.right-info {\n    width: 50%;\n    text-align: left;\n}\n.left-info p,\n.right-info p {\n    margin: 8px 0px;   /* increase this value (10px, 12px) if needed */\n}\n\n\n.address-table {\n    width: 100%;\n    border-collapse: collapse;\n    margin: 8px 15px 0 15px;\n    font-size: 14px;\n}\n\n.address-table th {\n    text-align: left;\n    padding: 8px;\n    border: 1px solid #999;\n    background-color: white;\n    font-weight: bold;\n}\n\n.address-table td {\n    padding: 8px;\n    border: 1px solid #999;\n    vertical-align: top;\n}",
